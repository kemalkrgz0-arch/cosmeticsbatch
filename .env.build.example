# Build-time config for deploy.sh. On the VPS, copy this to
# /opt/cosmeticsbatch/.env.build and fill in the blanks — that file is untracked
# so the codes never land in git.
#
# All of these are inlined into the client bundle at build time. Changing any of
# them needs a rebuild (./deploy.sh), not just a container restart. Every value
# here is a public identifier that already appears in the page source.

# Required. Canonical/OG/sitemap/hreflang. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://cosmeticsbatch.com

# Google AdSense. Blank client = ad placeholders + ads.txt returns 204.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-6300134697173168
NEXT_PUBLIC_ADSENSE_SLOT_HOME=
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_BRAND=

# Analytics. Blank = tracker not loaded at all (no script, no cookies).
NEXT_PUBLIC_GA_ID=G-LR51EM3ESQ
NEXT_PUBLIC_YM_ID=110450605

# Search Console / Bing Webmaster ownership <meta> tags. Blank = not rendered.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
